---
import { getCollection } from 'astro:content';
import Icon from './Icon.astro';

const base = import.meta.env.BASE_URL;
const accentVars = {
	cyan: 'var(--accent-cyan)',
	magenta: 'var(--accent-magenta)',
	violet: 'var(--accent-violet)',
	lime: 'var(--accent-lime)',
	orange: 'var(--accent-orange)',
} as const;

const features = (await getCollection('features'))
	.map(entry => ({
		id: entry.id,
		...entry.data,
		media: `${base}${entry.data.media}`,
		poster: entry.data.poster ? `${base}${entry.data.poster}` : undefined,
		accentVar: accentVars[entry.data.accent],
	}))
	.sort((a, b) => a.order - b.order);
---

<section class="section" id="features">
	<div class="container">
		<span class="section-label">Features</span>
		<h2 class="section-title">Everything you need to create</h2>
		<p class="section-desc">
			A complete GLSL development environment in your pocket &mdash; write, preview,
			and ship shaders without leaving your phone.
		</p>

		<div class="features-list">
			{features.map((f, i) => (
				<div class={`feature-row ${i % 2 === 1 ? 'feature-row-reverse' : ''}`}>
					<div class="feature-media">
						<div class="feature-phone" style={`--card-accent: ${f.accentVar};`}>
							<div class="feature-screen">
								{f.mediaType === 'video' ? (
									<video class="lazy-video" loop muted playsinline preload="none" poster={f.poster} data-src={f.media}>
										<source data-src={f.media} type="video/webm" />
									</video>
								) : (
									<img src={f.media} alt={f.title} loading="lazy" />
								)}
							</div>
						</div>
					</div>
					<div class="feature-text">
						<div class="feature-icon-wrap" style={`--icon-accent: ${f.accentVar};`}>
							<Icon name={f.icon} size={22} />
						</div>
						<h3 class="feature-title">{f.title}</h3>
						<p class="feature-desc-main">{f.desc}</p>
						<p class="feature-detail">{f.detail}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<script>
	const observer = new IntersectionObserver(entries => {
		entries.forEach(entry => {
			const video = entry.target;
			if (!(video instanceof HTMLVideoElement)) {
				return;
			}
			if (entry.isIntersecting) {
				const source = video.querySelector('source[data-src]');
				if (source) {
					const src = source.getAttribute('data-src');
					if (src) {
						source.setAttribute('src', src);
						source.removeAttribute('data-src');
						video.load();
					}
				}
				video.play().catch(() => {});
			} else {
				video.pause();
			}
		});
	}, { threshold: 0.3 });

	document.querySelectorAll('.lazy-video').forEach(v => observer.observe(v));
</script>

<style>
	.features-list {
		display: flex;
		flex-direction: column;
		gap: clamp(4rem, 8vw, 7rem);
		margin-top: 4rem;
	}

	.feature-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: center;
	}

	.feature-row-reverse { direction: rtl; }
	.feature-row-reverse > * { direction: ltr; }

	.feature-media {
		display: flex;
		justify-content: center;
	}

	.feature-phone {
		width: 220px;
		background: #1a1d2b;
		border-radius: 28px;
		padding: 8px;
		box-shadow:
			0 0 0 1px rgba(255,255,255,0.06),
			0 12px 40px rgba(0,0,0,0.4);
		position: relative;
		transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
	}

	.feature-phone::before {
		content: '';
		position: absolute;
		top: -1px; left: 20%; right: 20%; height: 1px;
		background: linear-gradient(90deg, transparent, var(--card-accent, var(--accent-cyan)), transparent);
		opacity: 0; transition: opacity 0.4s;
	}

	.feature-phone::after {
		content: '';
		position: absolute;
		width: 180px; height: 180px; border-radius: 50%;
		background: var(--card-accent);
		filter: blur(80px); opacity: 0;
		top: -40px; right: -40px;
		transition: opacity 0.5s;
		pointer-events: none; z-index: -1;
	}

	.feature-phone:hover {
		transform: translateY(-6px);
		box-shadow:
			0 0 0 1px rgba(255,255,255,0.1),
			0 20px 60px rgba(0,0,0,0.5),
			0 0 40px color-mix(in srgb, var(--card-accent) 12%, transparent);
	}

	.feature-phone:hover::before { opacity: 0.6; }
	.feature-phone:hover::after { opacity: 0.12; }

	.feature-screen {
		border-radius: 20px;
		overflow: hidden;
		aspect-ratio: 9/19;
		background: var(--bg-surface);
	}

	.feature-screen video,
	.feature-screen img {
		width: 100%; height: 100%; object-fit: cover;
	}

	.feature-icon-wrap {
		width: 44px; height: 44px;
		border-radius: 12px;
		background: color-mix(in srgb, var(--icon-accent) 10%, transparent);
		border: 1px solid color-mix(in srgb, var(--icon-accent) 20%, transparent);
		display: flex; align-items: center; justify-content: center;
		margin-bottom: 1rem;
		color: var(--icon-accent);
	}

	.feature-title {
		font-family: var(--font-display);
		font-size: 1.5rem; font-weight: 700;
		margin-bottom: 0.75rem;
	}

	.feature-desc-main {
		font-size: 1.05rem; color: var(--text-primary);
		line-height: 1.6; margin-bottom: 0.75rem;
	}

	.feature-detail {
		font-size: 0.9rem; color: var(--text-secondary);
		line-height: 1.8;
	}

	@media (max-width: 900px) {
		.feature-row, .feature-row-reverse {
			grid-template-columns: 1fr; direction: ltr;
		}
		.feature-media { justify-content: center; }
		.feature-phone { width: 180px; }
	}
</style>
