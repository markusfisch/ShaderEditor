---
interface FAQItem {
  q: string;
  a: string;
}

const faq: FAQItem[] = [
  {
    q: 'How do I use GLES 3.0 (or 3.1 / 3.2)?',
    a: 'Add <code>#version 300 es</code> (or <code>310 es</code>, <code>320 es</code>) as the very first line. Output changes from <code>gl_FragColor</code> to an <code>out vec4</code> variable. Your device must support the requested version.',
  },
  {
    q: 'How many FPS do I need for a live wallpaper?',
    a: 'Aim for at least ~30 FPS with the keyboard hidden and no charger plugged in. Some devices throttle the GPU on battery. Use the quality spinner (1/2, 1/4, etc.) to lower the render resolution and gain FPS.',
  },
  {
    q: 'How much battery does a live wallpaper use?',
    a: 'Only renders when visible, so normal usage has negligible impact. When "Save battery" is enabled (default), rendering pauses on low battery — drawing stops almost completely.',
  },
  {
    q: 'Errors are not highlighted on my device?',
    a: 'Some GPU drivers don\'t report compile errors back to apps. On those devices error highlighting won\'t work, but your shader still compiles and runs normally.',
  },
  {
    q: '"Set wallpaper" doesn\'t work?',
    a: 'You must first set ShaderEditor as your live wallpaper provider: <strong>System Settings → Display → Wallpaper → Live Wallpapers → Shader Editor</strong>. After that, \u201cSet as wallpaper\u201d and \u201cUpdate wallpaper\u201d in the app menu will work.',
  },
  {
    q: 'The time uniform loses precision after a while?',
    a: 'This is a floating-point precision issue — <code>mediump float</code> only has ~6 significant digits. Solutions: use <code>highp float</code> if your GPU supports it, switch to the <code>second</code> + <code>subsecond</code> uniforms which don\'t accumulate, or use <code>ftime</code> with <code>#define FTIME_PERIOD</code> for cyclic animations.',
  },
  {
    q: 'How does the backbuffer work?',
    a: 'Declare <code>uniform sampler2D backbuffer;</code> and sample the previous frame with <code>texture2D(backbuffer, uv)</code>. This enables stateful effects: trails, blur, cellular automata. Add <code>///p:noise</code> after the declaration to initialize with a noise texture instead of black.',
  },
  {
    q: 'Can I paste ShaderToy code directly?',
    a: 'Yes. If pasted code has a <code>mainImage()</code> function, ShaderEditor auto-converts it: <code>iResolution</code>→<code>resolution</code>, <code>iGlobalTime</code>→<code>time</code>, <code>iMouse</code>→<code>mouse</code>, <code>iDate</code>→<code>date</code>. A wrapper <code>main()</code> is generated automatically.',
  },
  {
    q: 'How do I import/export shaders?',
    a: 'Use Settings → Import/Export Database to backup and restore your entire shader collection, including textures. On older Android versions (below 10) you can also export individual <code>.glsl</code> files to <code>Downloads/ShaderEditor</code>.',
  },
  {
    q: 'Can I use custom textures?',
    a: 'Yes. Menu → Add Uniform → 2D Textures or Cube Maps tab. Pick an image, crop if needed, set sampler parameters (wrap, filter), and the <code>uniform sampler2D yourTexture;</code> statement is inserted into your code.',
  },
  {
    q: 'What is the #define SHADER_EDITOR macro?',
    a: '<code>#define SHADER_EDITOR 1</code> is automatically injected into every shader. Use <code>#ifdef SHADER_EDITOR</code> to conditionally include code that only runs inside ShaderEditor (useful for portable shaders).',
  },
  {
    q: 'What fonts are available?',
    a: 'Several popular coding fonts are built in, including JetBrains Mono, Fira Code, and Source Code Pro. Ligature support can be toggled independently. Set your preferred font in Settings → Editor → Font.',
  },
  {
    q: 'How do I change render resolution?',
    a: 'Use the quality spinner in the toolbar (1/32 to 2×). Lower values render at a fraction of screen resolution — great for complex shaders or battery savings. Each shader remembers its own quality setting.',
  },
  {
    q: 'Can both cameras be used at the same time?',
    a: 'No — Android only allows one camera at a time. You can switch between front and back, but not use both simultaneously.',
  },
  {
    q: 'Where can I learn more about shaders?',
    a: '<a href="https://thebookofshaders.com/" target="_blank" rel="noopener">The Book of Shaders</a> (beginner), <a href="https://docs.gl/" target="_blank" rel="noopener">OpenGL API Reference</a>, <a href="https://en.wikibooks.org/wiki/GLSL_Programming" target="_blank" rel="noopener">GLSL Programming on Wikibooks</a>, and the <a href="https://www.khronos.org/files/opengles_shading_language.pdf" target="_blank" rel="noopener">GLES Shading Language spec</a>.',
  },
];
---

<section class="section" id="faq">
  <div class="container">
    <span class="section-label">FAQ</span>
    <h2 class="section-title">Common questions</h2>

    <div class="faq-list">
      {faq.map(item => (
        <details class="faq-item">
          <summary class="faq-question">
            <span class="faq-q-text">{item.q}</span>
            <span class="faq-chevron">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 8 10 12 14 8"/>
              </svg>
            </span>
          </summary>
          <div class="faq-answer" set:html={item.a} />
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-list {
    max-width: 800px;
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq-item {
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.3s;
  }

  .faq-item[open] {
    border-color: rgba(0, 229, 255, 0.15);
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.125rem 1.5rem;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    list-style: none;
    gap: 1rem;
    transition: background 0.2s;
  }

  .faq-question::-webkit-details-marker { display: none; }

  .faq-question:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  .faq-chevron {
    color: var(--text-muted);
    transition: transform 0.3s;
    flex-shrink: 0;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--accent-cyan);
  }

  .faq-answer {
    padding: 0 1.5rem 1.25rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .faq-answer code {
    font-family: var(--font-mono);
    font-size: 0.775rem;
    background: rgba(0, 229, 255, 0.08);
    color: var(--accent-cyan);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .faq-answer a {
    color: var(--accent-cyan);
    text-decoration: underline;
    text-decoration-color: rgba(0, 229, 255, 0.3);
    text-underline-offset: 3px;
  }

  .faq-answer a:hover {
    text-decoration-color: var(--accent-cyan);
  }

  .faq-answer strong {
    color: var(--text-primary);
  }
</style>
